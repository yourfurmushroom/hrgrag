# Copy to config.env and adjust for the target machine.

PYTHON_BIN=
DATASET=custom
SPLIT=test

# Required for all runs.
KB_PATH=/absolute/path/to/your/kb.txt

# Built-in datasets: set DATASET_ROOT.
DATASET_ROOT=

# Custom dataset mode: required when DATASET=custom.
DATASET_FILE=/absolute/path/to/your/questions.jsonl
CUSTOM_DATASET_NAME=mydataset
CUSTOM_FORMAT=jsonl
CUSTOM_HOP=1

# Downloader-backed normalized datasets also support:
# DATASET=wqsp | cwq | kqapro | mintaka
# If DATASET_FILE is empty, run_pipeline.sh will use:
#   Datasets/<Name>/normalized/<SPLIT>.jsonl

# Optional files.
RELATION_PATH=
GRAMMAR_PATH=

# Pipeline behavior.
RUN_GRAMMAR=1
SAMPLE_LIMIT=100
MODEL_FILTER=

# Dataset-specific knobs.
METAQA_VARIANT=vanilla
WIKIMOVIES_SUBSET=wiki_entities
MLPQ_PAIR=en-zh
MLPQ_QUESTION_LANG=en
MLPQ_FUSION=ills

# Output locations.
OUTPUT_FILE=
DETAIL_CSV=

# Optional downloader overrides.
WQSP_HF_ID=ml1996/webqsp
CWQ_HF_ID=drt/complex_web_questions
KQAPRO_HF_ID=soongfs/kqa_pro
MINTAKA_HF_ID=AmazonScience/mintaka
